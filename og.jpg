  try {
    var ua = (navigator && navigator.userAgent) || "";
    if (!ua || ua.indexOf("Hyperagent-Mobile") !== -1) return;
    var META = /\b(FBAN|FBAV|FB_IAB|Instagram)\b/;
    var isAndroidWebView = /Android.*; wv\)/.test(ua) || (/Android/.test(ua) && META.test(ua));
    var isAppleMobile = /\((iPhone|iPad|iPod)/.test(ua);
    var isWKWebView = isAppleMobile && /AppleWebKit/.test(ua) && /Mobile\/\S+/.test(ua) && !/Safari\/\S+/.test(ua);
    if (!isAndroidWebView && !isWKWebView) return;
    function rewrite(url) {
      if (isWKWebView) {
        return url.replace(/^https?:\/\//, function(m){ return "x-safari-" + m; });
      }
      try {
        var u = new URL(url);
        return "intent://" + u.host + u.pathname + u.search +
          "#Intent;scheme=" + u.protocol.replace(":","") +
          ";action=android.intent.action.VIEW" +
          ";S.browser_fallback_url=" + encodeURIComponent(url) +
          ";end";
      } catch (e) { return null; }
    }
    document.addEventListener("click", function(e){
      var node = e.target;
      while (node && node !== document) {
        if (node.tagName === "A") {
          if (node.hasAttribute("data-no-escape")) return;
          if (node.hasAttribute("download")) return;
          var href = node.getAttribute("href") || "";
          var abs = node.href;
          if (!abs || !/^https?:\/\//i.test(abs)) return;
          if (/^(mailto:|tel:|sms:|javascript:|#)/i.test(href)) return;
          var escaped = rewrite(abs);
          if (escaped) {
            node.href = escaped;
            if (e.preventDefault) e.preventDefault();
            if (e.stopImmediatePropagation) e.stopImmediatePropagation();
            try { window.location.href = escaped; } catch (err) {}
          }
          return;
        }
        node = node.parentNode;
      }
    }, true);
  } catch (e) {}
})();</script><script id="user-identity-bootstrap">try{window.__USER_IDENTITY__={"userId":"cmokfprj40hy306ad9ocst4hy"}}catch(e){window.__USER_IDENTITY__=null}</script><script id="client-perf-config-bootstrap">try{window.__CLIENT_PERF_CONFIG__={"enabled":false,"inpThresholdMs":0,"loafThresholdMs":0,"iframeCountThreshold":0,"maxReportsPerPageLoad":0}}catch(e){window.__CLIENT_PERF_CONFIG__=undefined}</script><script id="default-agent-backend-bootstrap">try{window.__DEFAULT_AGENT_BACKEND__="vercel-sandbox"}catch(e){window.__DEFAULT_AGENT_BACKEND__=undefined}</script><script data-cfasync="false" src="./og_files/airgap.js.download"></script><link rel="preload" href="https://static.hyperagent.com/24c507e3cdb7cce7f412df4c6292f37a0a87d821/_next/static/media/797e433ab948586e-s.p.08e28id.o-okb.woff2" as="font" crossorigin="" type="font/woff2"><link rel="preload" href="https://static.hyperagent.com/24c507e3cdb7cce7f412df4c6292f37a0a87d821/_next/static/media/ATSeasonSansVF-s.p.025d~pt0x11ro.woff2" as="font" crossorigin="" type="font/woff2"><link rel="preload" href="https://static.hyperagent.com/24c507e3cdb7cce7f412df4c6292f37a0a87d821/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2" as="font" crossorigin="" type="font/woff2"><style type="text/css">[data-sonner-toaster][dir=ltr],html[dir=ltr]{--toast-icon-margin-start:-3px;--toast-icon-margin-end:4px;--toast-svg-margin-start:-1px;--toast-svg-margin-end:0px;--toast-button-margin-start:auto;--toast-button-margin-end:0;--toast-close-button-start:0;--toast-close-button-end:unset;--toast-close-button-transform:translate(-35%, -35%)}[data-sonner-toaster][dir=rtl],html[dir=rtl]{--toast-icon-margin-start:4px;--toast-icon-margin-end:-3px;--toast-svg-margin-start:0px;--toast-svg-margin-end:-1px;--toast-button-margin-start:0;--toast-button-margin-end:auto;--toast-close-button-start:unset;--toast-close-button-end:0;--toast-close-button-transform:translate(35%, -35%)}[data-sonner-toaster]{position:fixed;width:var(--width);font-fam