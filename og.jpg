<div class="my-2"><div class="not-prose my-4 max-w-full"><div class="group/card relative flex overflow-hidden rounded-xl border w-fit" style="--native-media-max-h: 400px;"><div class="inline-flex max-h-native-media min-h-0 w-fit min-w-0 max-w-full items-center justify-start overflow-hidden rounded-[14px] bg-muted/30"><img alt="og.jpg" class="size-auto max-h-native-media max-w-full object-contain" src="./og_files/957f6eff-1829-4699-b6ff-6964c926b2ab.jpg"></div><button type="button" aria-label="View fullscreen" class="absolute inset-0 z-10 cursor-pointer"></button></div><div class="mt-1.5 flex min-w-0 items-center gap-1"><div class="truncate text-muted-foreground text-xs">og.jpg</div></div></div></div>
